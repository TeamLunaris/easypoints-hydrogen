# Local MiniOxygen environment. Copy to `.env` and fill in.
# Run `h2 link` / `h2 env pull` to also inject Storefront API credentials.
SESSION_SECRET="foobar"

# easyPoints loyalty credentials (read in app/lib/context.ts).
# Bearer token issued by easyPoints — required for authenticated loyalty requests.
EASY_POINTS_API_TOKEN=
# Optional: override the loyalty API base (defaults to https://loyalty.slrs.io/api).
EASY_POINTS_API_ENDPOINT=
